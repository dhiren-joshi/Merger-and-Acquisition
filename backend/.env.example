# ===========================================
# M&A Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/mna_platform
# MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# JWT Secret Keys
# IMPORTANT: Change these to unique random strings in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret_key
JWT_REFRESH_SECRET=change_this_to_another_random_secret_key
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# CORS - Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email Notifications (Optional - disabled by default)
# ENABLE_EMAIL_NOTIFICATIONS=true
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password
